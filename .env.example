# ===================
# Discord Bot 配置
# ===================

# Discord Bot Token (从 https://discord.com/developers/applications 获取)
DISCORD_BOT_TOKEN=

# Discord Bot ID (从 Discord Developer Portal 获取, 或从 Token 解析)
DISCORD_BOT_ID=

# ===================
# Telegram Bot 配置 (可选)
# ===================

TELEGRAM_BOT_TOKEN=

# ===================
# Anthropic API 配置
# ===================

# 认证方式二选一:
# 1. PROXY_MANAGED - 使用本地凭证代理 (推荐)
# 2. 直接填 API Key
ANTHROPIC_AUTH_TOKEN=PROXY_MANAGED
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# API 服务器地址
# - 本地代理: http://127.0.0.1:5000
# - 云端代理: http://192.168.64.1:5000
# - 直连: https://api.anthropic.com
# - 其他 API 兼容服务: https://your-api-server.com
ANTHROPIC_BASE_URL=http://127.0.0.1:5000

# API 超时 (毫秒)
API_TIMEOUT_MS=3000000

# 禁止非必要流量
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# ===================
# Bot 身份配置
# ===================

# 触发词 (@xxx), 必须与 Discord Bot 用户名匹配
ASSISTANT_NAME=Andy

# Bot 是否有自己的号码 (WhatsApp 用)
# ASSISTANT_HAS_OWN_NUMBER=false

# ===================
# ComfyUI 图片生成
# ===================

# 方式一: 直接指定服务器地址 (优先级最高)
COMFYUI_SERVER=

# 方式二: 使用预设模式 (选一个)
# host_vm   - 宿主机网关 (COMFYUI_HOST_VM)
# internal  - 局域网服务器 (COMFYUI_INTERNAL)
# external  - 外网服务器 (COMFYUI_EXTERNAL)
# custom    - 自定义地址
COMFYUI_MODE=host_vm

# 预设地址 (可自定义)
COMFYUI_HOST_VM=192.168.64.1:7860     # 宿主机 Apple Container 网关
COMFYUI_INTERNAL=192.168.31.8:7860    # 局域网服务器
COMFYUI_EXTERNAL=http://your-server:7860  # 外网服务器

# 图片尺寸
COMFYUI_WIDTH=512
COMFYUI_HEIGHT=1024

# ===================
# 网络代理 (中国大陆环境)
# ===================

# SOCKS5 代理 (用于 curl、Discord 等)
SOCKS5_PROXY=socks5://127.0.0.1:7890

# HTTP/HTTPS 代理 (用于其他 HTTP 请求)
https_proxy=socks5://127.0.0.1:7890
http_proxy=socks5://127.0.0.1:7890

# HTTP 代理 (用于 Node.js 全局)
# GLOBAL_AGENT_HTTP_PROXY=http://127.0.0.1:7890

# ===================
# 凭证代理
# ===================

# 端口 (多实例时需不同端口)
CREDENTIAL_PROXY_PORT=3001

# 绑定地址 (通常不需要修改)
# CREDENTIAL_PROXY_HOST=auto

# ===================
# 容器配置
# ===================

# 容器镜像
CONTAINER_IMAGE=nanoclaw-agent:latest

# 容器超时 (毫秒, 默认 30 分钟)
CONTAINER_TIMEOUT=1800000

# 容器最大输出 (字节, 默认 10MB)
CONTAINER_MAX_OUTPUT_SIZE=10485760

# 最大并发容器数
MAX_CONCURRENT_CONTAINERS=5

# 空闲超时 (毫秒) - 容器保持活跃时间
IDLE_TIMEOUT=1800000

# ===================
# 安全配置
# ===================

# 挂载白名单路径 (默认 ~/.config/nanoclaw/)
# MOUNT_ALLOWLIST_PATH=

# 发送者白名单路径
# SENDER_ALLOWLIST_PATH=

# ===================
# 日志
# ===================

# 级别: trace | debug | info | warn | error
LOG_LEVEL=info

# ===================
# 时区
# ===================

TZ=Asia/Shanghai

# ===================
# 其他
# ===================

# 项目根目录 (通常不需要修改)
# NANOCLAW_ROOT=/path/to/project

# Chrome 路径 (浏览器自动化)
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
